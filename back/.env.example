APP_NAME=Pain
APP_ENV=local
APP_KEY=base64:48nEG7U+jWe3/tX7POK17T4I13Uq8OxBSM0x83fRf+w=
APP_DEBUG=true
APP_URL=https://10.37.44.221

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Base de données (pré-configurée pour Docker) ────────────────────────
DB_CONNECTION=pgsql
DB_HOST=pain-db
DB_PORT=5432
DB_DATABASE=pain
DB_USERNAME=pain
DB_PASSWORD=pain

# ─── Cache (table PostgreSQL) ────────────────────────────────────────────
CACHE_STORE=database

# ─── Connexion SSH au serveur VTOM (récupération du plan) ────────────────
VTOM_SSH_HOST=10.37.44.206
VTOM_SSH_PORT=22
VTOM_SSH_USERNAME=vtom
VTOM_SSH_PASSWORD=vtom
VTOM_SSH_FILE_PATH=/home/vtom/PAY_TOURS.xml

# ─── Connexion SSH via jump host (récupération des scripts) ──────────────
JUMP_HOST=172.16.197.7
JUMP_PORT=22
JUMP_USERNAME=pay
JUMP_PASSWORD=pay

TARGET_HOST=172.16.197.131
TARGET_PORT=22
TARGET_USERNAME=pay
TARGET_PASSWORD=pay

# ─── Paramétrage VTOM (optionnel, défauts dans config/vtom.php) ──────────
# VTOM_SCRIPTS_PATH=/var/www/scripts
# VTOM_CACHE_DURATION=300

# ─── Redis (refresh tokens) ──────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=pain-redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# ─── Cookies ─────────────────────────────────────────────────────────────
COOKIE_SECURE=true

# ─── Authentification LDAP ───────────────────────────────────────────────
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=dc=example,dc=fr
LDAP_USERNAME=cn=service,dc=example,dc=fr
LDAP_PASSWORD=
LDAP_SSL=false
LDAP_TLS=false
